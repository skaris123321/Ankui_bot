<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Роли за активность - Панель управления</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root {
      --sidebar-width: 180px;
      --border-radius: 12px;
      --transition: all 0.2s ease;
    }
    
    .dashboard-container {
      display: flex;
      min-height: calc(100vh - 80px);
      background: var(--background);
    }
    
    .sidebar {
      width: var(--sidebar-width);
      background: #1E1F22;
      border-right: 1px solid rgba(255, 255, 255, 0.08);
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      overflow-x: hidden;
    }
    
    .sidebar-user-profile {
      padding: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    
    .sidebar-user-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--primary-color);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }
    
    .sidebar-user-avatar img {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
    }
    
    .sidebar-user-name {
      flex: 1;
      min-width: 0;
      font-weight: 600;
      color: var(--text-primary);
      font-size: 0.9rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    .sidebar-nav-category {
      margin-top: 0.5rem;
      padding: 0.5rem 0;
    }
    
    .sidebar-nav-category-title {
      padding: 0.5rem 1rem;
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .sidebar-nav-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.625rem 1rem;
      color: var(--text-secondary);
      text-decoration: none;
      transition: var(--transition);
      border-left: 3px solid transparent;
    }
    
    .sidebar-nav-item:hover {
      background: rgba(255, 255, 255, 0.05);
      color: var(--text-primary);
    }
    
    .sidebar-nav-item.active {
      background: rgba(88, 101, 242, 0.15);
      color: var(--text-primary);
      border-left-color: var(--primary-color);
    }
    
    .sidebar-nav-item-icon {
      width: 20px;
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    
    .sidebar-nav-item-icon svg {
      width: 100%;
      height: 100%;
    }
    
    .sidebar-nav-item-text {
      font-size: 0.875rem;
      font-weight: 500;
    }
    
    .main-content {
      flex: 1;
      padding: 2rem;
      overflow-y: auto;
    }
    
    .page-header {
      margin-bottom: 2rem;
    }
    
    .page-header h1 {
      color: var(--text-primary);
      font-size: 2rem;
      margin: 0 0 0.5rem 0;
    }
    
    .page-header p {
      color: var(--text-secondary);
      font-size: 0.9rem;
      margin: 0;
    }
    
    .settings-section {
      background: var(--background-light);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--border-radius);
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }
    
    .settings-section h2 {
      color: var(--text-primary);
      font-size: 1.25rem;
      margin: 0 0 1rem 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .settings-section label {
      display: block;
      color: var(--text-primary);
      font-weight: 600;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
    }
    
    .settings-section .input-field,
    .settings-section select {
      width: 100%;
      padding: 0.75rem;
      background: var(--background);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 6px;
      color: var(--text-primary);
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    
    .settings-section .input-field:focus,
    .settings-section select:focus {
      outline: none;
      border-color: var(--primary-color);
    }
    
    .settings-section small {
      display: block;
      color: var(--text-secondary);
      font-size: 0.75rem;
      margin-top: -0.75rem;
      margin-bottom: 1rem;
    }
    
    .toggle-switch {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    
    .toggle-switch input[type="checkbox"] {
      width: 44px;
      height: 24px;
      appearance: none;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      position: relative;
      cursor: pointer;
      transition: var(--transition);
    }
    
    .toggle-switch input[type="checkbox"]:checked {
      background: var(--primary-color);
    }
    
    .toggle-switch input[type="checkbox"]::before {
      content: '';
      position: absolute;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: white;
      top: 2px;
      left: 2px;
      transition: var(--transition);
    }
    
    .toggle-switch input[type="checkbox"]:checked::before {
      left: 22px;
    }
    
    .toggle-switch label {
      margin: 0;
      cursor: pointer;
    }
    
    .role-list {
      margin-top: 1rem;
    }
    
    .role-item {
      background: var(--background);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 0.75rem;
    }
    
    .role-item-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }
    
    .role-item-info {
      flex: 1;
    }
    
    .role-item-name {
      color: var(--text-primary);
      font-weight: 600;
      margin-bottom: 0.25rem;
      font-size: 1rem;
    }
    
    .role-item-actions {
      display: flex;
      gap: 0.5rem;
    }
    
    .role-item-requirements {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    
    .btn {
      padding: 0.5rem 1rem;
      border: none;
      border-radius: 6px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
    }
    
    .btn-primary {
      background: var(--primary-color);
      color: white;
    }
    
    .btn-primary:hover {
      background: #4752C4;
    }
    
    .btn-danger {
      background: #ED4245;
      color: white;
    }
    
    .btn-danger:hover {
      background: #C03537;
    }
    
    .btn-secondary {
      background: rgba(255, 255, 255, 0.1);
      color: var(--text-primary);
    }
    
    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.15);
    }
    
    .add-role-form {
      background: var(--background);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 1rem;
      margin-top: 1rem;
    }
    
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    
    .form-row.full {
      grid-template-columns: 1fr;
    }
    
    .info-box {
      background: rgba(88, 101, 242, 0.1);
      border-left: 3px solid var(--primary-color);
      padding: 0.75rem;
      margin-bottom: 1rem;
      border-radius: 4px;
    }
    
    .info-box strong {
      color: var(--text-primary);
    }
    
    .info-box p {
      color: var(--text-secondary);
      font-size: 0.85rem;
      margin: 0.5rem 0 0 0;
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  
  <main class="dashboard-container">
    <!-- Боковая панель навигации -->
    <div class="sidebar">
      <div class="sidebar-user-profile">
        <div class="sidebar-user-avatar">
          <% if (user && user.avatar) { %>
            <img src="<%= user.avatar %>" alt="<%= user.username %>">
          <% } else { %>
            🤖
          <% } %>
        </div>
        <div class="sidebar-user-name">
          <% if (user) { %>
            <%= user.username %>
          <% } else { %>
            Гость
          <% } %>
        </div>
      </div>
      
      <div class="sidebar-nav-category">
        <div class="sidebar-nav-category-title">ОБЩЕЕ</div>
        <a href="/dashboard/overview" class="sidebar-nav-item <%= currentPage === 'overview' ? 'active' : '' %>">
          <div class="sidebar-nav-item-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div class="sidebar-nav-item-text">Обзор</div>
        </a>
        <a href="/dashboard" class="sidebar-nav-item <%= currentPage === 'embed-editor' ? 'active' : '' %>">
          <div class="sidebar-nav-item-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <path d="M9 9h6M9 15h6M9 12h6"/>
            </svg>
          </div>
          <div class="sidebar-nav-item-text">Embed-сообщения</div>
        </a>
      </div>
      
      <div class="sidebar-nav-category">
        <div class="sidebar-nav-category-title">НАСТРОЙКИ МОДУЛЕЙ</div>
        <a href="/dashboard/stream-notifications" class="sidebar-nav-item <%= currentPage === 'stream-notifications' ? 'active' : '' %>">
          <div class="sidebar-nav-item-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="sidebar-nav-item-text">Уведомление о стримах</div>
        </a>
        <a href="/dashboard/activity-roles" class="sidebar-nav-item <%= currentPage === 'activity-roles' ? 'active' : '' %>">
          <div class="sidebar-nav-item-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <div class="sidebar-nav-item-text">Роли за активность</div>
        </a>
      </div>
    </div>
    
    <!-- Основной контент -->
    <div class="main-content">
      <div class="page-header">
        <h1>🎖️ Роли за активность</h1>
        <p>Настройте автоматическую выдачу ролей за активность в чате и время в голосовых каналах</p>
      </div>
      
      <!-- Выбор сервера -->
      <div class="settings-section">
        <h2>Выберите сервер</h2>
        <% if (guilds.length > 0) { %>
          <select id="serverSelect" class="input-field" onchange="loadActivityRolesSettings(this.value)">
            <option value="">Выберите сервер...</option>
            <% guilds.forEach(guild => { %>
              <option value="<%= guild.id %>"><%= guild.name %></option>
            <% }); %>
          </select>
        <% } else { %>
          <p style="color: var(--text-secondary);">Бот не добавлен ни на один сервер</p>
        <% } %>
      </div>
      
      <!-- Основные настройки -->
      <div class="settings-section" id="mainSettings" style="display: none;">
        <h2>⚙️ Основные настройки</h2>
        
        <div class="toggle-switch">
          <input type="checkbox" id="activityRolesEnabled" onchange="saveActivityRolesSettings()">
          <label for="activityRolesEnabled">Включить систему ролей за активность</label>
        </div>
        
        <div class="info-box">
          <strong>💡 Информация:</strong>
          <p>
            Роли ранга выдаются за определённое количество сообщений в чате и проведённое время в голосовых каналах.<br>
            Вы можете настроить несколько ролей с разными требованиями. Роли будут выдаваться автоматически при достижении требований.
          </p>
        </div>
      </div>
      
      <!-- Список ролей -->
      <div class="settings-section" id="rolesSection" style="display: none;">
        <h2>🎖️ Настроенные роли</h2>
        
        <div class="role-list" id="rolesList">
          <!-- Список ролей будет загружен динамически -->
        </div>
        
        <div class="add-role-form">
          <h3 style="color: var(--text-primary); font-size: 1rem; margin-bottom: 1rem;">Добавить роль</h3>
          <div class="form-row full">
            <div>
              <label>Роль</label>
              <select id="roleSelect" class="input-field">
                <option value="">Выберите роль...</option>
              </select>
              <small>Роль, которая будет выдана при достижении требований</small>
            </div>
          </div>
          <div class="form-row">
            <div>
              <label>Количество сообщений</label>
              <input type="number" id="roleMessages" class="input-field" min="0" placeholder="0" step="100">
              <small>Минимальное количество сообщений (например: 1000 для 1k сообщений)</small>
            </div>
            <div>
              <label>Время в голосовых каналах (часы)</label>
              <input type="number" id="roleVoiceHours" class="input-field" min="0" placeholder="0" step="1">
              <small>Минимальное время в голосовых каналах в часах (например: 200 для 200h)</small>
            </div>
          </div>
          <button type="button" class="btn btn-primary" onclick="addRole()">Добавить роль</button>
        </div>
      </div>
      
    </div>
  </main>
  
  <script>
    let selectedGuildId = null;
    let roles = [];
    let availableRoles = [];
    
    // Загружаем сохраненный сервер при загрузке страницы
    window.addEventListener('DOMContentLoaded', () => {
      const savedGuildId = localStorage.getItem('activityRoles_selectedGuildId');
      if (savedGuildId) {
        const select = document.getElementById('serverSelect');
        if (select) {
          select.value = savedGuildId;
          loadActivityRolesSettings(savedGuildId);
        }
      }
    });
    
    async function loadActivityRolesSettings(guildId) {
      if (!guildId) return;
      
      selectedGuildId = guildId;
      
      // Сохраняем выбранный сервер в localStorage
      localStorage.setItem('activityRoles_selectedGuildId', guildId);
      
      // Показываем секции настроек
      document.getElementById('mainSettings').style.display = 'block';
      document.getElementById('rolesSection').style.display = 'block';
      
      // Загружаем роли сервера и настройки параллельно
      await Promise.all([
        loadRoles(guildId),
        loadSettings(guildId)
      ]);
    }
    
    async function loadRoles(guildId) {
      try {
        const response = await fetch(`/api/guild/${guildId}/roles`);
        const data = await response.json();
        
        if (data.success && data.roles) {
          availableRoles = data.roles;
          
          const select = document.getElementById('roleSelect');
          if (select) {
            select.innerHTML = '<option value="">Выберите роль...</option>';
            
            data.roles.forEach(role => {
              const option = document.createElement('option');
              option.value = role.id;
              option.textContent = role.name;
              option.style.color = role.color || '#FFFFFF';
              select.appendChild(option);
            });
          }
        }
      } catch (error) {
        console.error('Ошибка загрузки ролей:', error);
      }
    }
    
    async function loadSettings(guildId) {
      try {
        const response = await fetch(`/api/guild/${guildId}/activity-roles`);
        const data = await response.json();
        
        if (data.success && data.data) {
          const settings = data.data;
          
          // Устанавливаем значения полей
          const enabledCheckbox = document.getElementById('activityRolesEnabled');
          if (enabledCheckbox) enabledCheckbox.checked = settings.enabled || false;
          
          if (settings.roles && Array.isArray(settings.roles)) {
            roles = settings.roles.map(r => ({
              id: r.id || Date.now() + Math.random(),
              roleId: r.roleId || '',
              messages: r.messages || 0,
              voiceHours: r.voiceHours || 0
            }));
          } else {
            roles = [];
          }
          
          renderRoles();
        } else {
          roles = [];
          renderRoles();
        }
      } catch (error) {
        console.error('Ошибка загрузки настроек:', error);
        roles = [];
        renderRoles();
      }
    }
    
    async function saveActivityRolesSettings() {
      if (!selectedGuildId) {
        showMessage('error', '❌ Выберите сервер перед сохранением');
        return;
      }
      
      const settings = {
        enabled: document.getElementById('activityRolesEnabled').checked,
        roles: roles.map(r => ({
          id: r.id,
          roleId: r.roleId,
          messages: parseInt(r.messages) || 0,
          voiceHours: parseInt(r.voiceHours) || 0
        }))
      };
      
      try {
        const response = await fetch(`/api/guild/${selectedGuildId}/activity-roles`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(settings)
        });
        
        const result = await response.json();
        if (result.success) {
          showMessage('success', '✅ Настройки сохранены!');
          await loadSettings(selectedGuildId);
        } else {
          showMessage('error', '❌ Ошибка сохранения: ' + (result.message || 'Неизвестная ошибка'));
        }
      } catch (error) {
        console.error('Ошибка сохранения настроек:', error);
        showMessage('error', '❌ Ошибка сохранения настроек');
      }
    }
    
    function addRole() {
      const roleId = document.getElementById('roleSelect').value;
      const messages = parseInt(document.getElementById('roleMessages').value) || 0;
      const voiceHours = parseInt(document.getElementById('roleVoiceHours').value) || 0;
      
      if (!roleId) {
        showMessage('error', '❌ Выберите роль');
        return;
      }
      
      if (messages === 0 && voiceHours === 0) {
        showMessage('error', '❌ Укажите хотя бы одно требование (сообщения или время в войсе)');
        return;
      }
      
      // Проверяем, не добавлена ли уже эта роль
      if (roles.some(r => r.roleId === roleId)) {
        showMessage('error', '❌ Эта роль уже добавлена');
        return;
      }
      
      const role = availableRoles.find(r => r.id === roleId);
      
      roles.push({
        id: Date.now(),
        roleId: roleId,
        roleName: role ? role.name : 'Неизвестная роль',
        messages: messages,
        voiceHours: voiceHours
      });
      
      // Очищаем форму
      document.getElementById('roleSelect').value = '';
      document.getElementById('roleMessages').value = '';
      document.getElementById('roleVoiceHours').value = '';
      
      renderRoles();
      saveActivityRolesSettings();
      showMessage('success', '✅ Роль добавлена!');
    }
    
    function removeRole(roleId) {
      roles = roles.filter(r => r.id !== roleId);
      renderRoles();
      saveActivityRolesSettings();
    }
    
    function renderRoles() {
      const container = document.getElementById('rolesList');
      container.innerHTML = '';
      
      if (roles.length === 0) {
        container.innerHTML = '<p style="color: var(--text-secondary); text-align: center; padding: 1rem;">Нет настроенных ролей</p>';
        return;
      }
      
      // Сортируем роли по требованиям (от большего к меньшему)
      const sortedRoles = [...roles].sort((a, b) => {
        const aTotal = (a.messages || 0) + (a.voiceHours || 0) * 100;
        const bTotal = (b.messages || 0) + (b.voiceHours || 0) * 100;
        return bTotal - aTotal;
      });
      
      sortedRoles.forEach(role => {
        const roleData = availableRoles.find(r => r.id === role.roleId);
        const roleName = roleData ? roleData.name : (role.roleName || 'Неизвестная роль');
        const roleColor = roleData ? roleData.color : '#FFFFFF';
        
        const item = document.createElement('div');
        item.className = 'role-item';
        item.innerHTML = `
          <div class="role-item-header">
            <div class="role-item-info">
              <div class="role-item-name" style="color: ${roleColor};">${escapeHtml(roleName)}</div>
            </div>
            <div class="role-item-actions">
              <button type="button" class="btn btn-danger" onclick="removeRole(${role.id})">Удалить</button>
            </div>
          </div>
          <div class="role-item-requirements">
            <div>
              <strong style="color: var(--text-primary); display: block; margin-bottom: 0.25rem;">Сообщений:</strong>
              <span style="color: var(--text-secondary);">${formatNumber(role.messages || 0)}</span>
            </div>
            <div>
              <strong style="color: var(--text-primary); display: block; margin-bottom: 0.25rem;">Время в войсе:</strong>
              <span style="color: var(--text-secondary);">${formatNumber(role.voiceHours || 0)}h</span>
            </div>
          </div>
        `;
        container.appendChild(item);
      });
    }
    
    function formatNumber(num) {
      if (num >= 1000) {
        return (num / 1000).toFixed(1) + 'k';
      }
      return num.toString();
    }
    
    function escapeHtml(text) {
      if (!text) return '';
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
    
    function showMessage(type, message) {
      const div = document.createElement('div');
      div.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 1rem 1.5rem;
        background: ${type === 'success' ? '#43B581' : '#ED4245'};
        color: white;
        border-radius: 8px;
        z-index: 10000;
        font-weight: 600;
      `;
      div.textContent = message;
      document.body.appendChild(div);
      
      setTimeout(() => {
        div.remove();
      }, 3000);
    }
  </script>
