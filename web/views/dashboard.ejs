    // Конвертация файла в base64 и загрузка на сервер
    // Загрузка файла на сервер
    async function uploadFile(file) {
      return new Promise((resolve, reject) => {
        // Проверяем размер файла (максимум 10 МБ)
        if (file.size > 10 * 1024 * 1024) {
          reject(new Error('Размер файла не должен превышать 10 МБ'));
          return;
        }
        
        // Проверяем тип файла
        const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp', 'image/jpg'];
        if (!allowedTypes.includes(file.type)) {
          reject(new Error('Разрешены только изображения (JPEG, PNG, GIF, WEBP)'));
          return;
        }
        
        // Создаём FormData для отправки файла
        const formData = new FormData();
        formData.append('image', file);
        
        // Отправляем файл на сервер
        fetch('/api/upload-image', {
          method: 'POST',
          body: formData
        })
        .then(response => {
          if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
          }
          return response.json();
        })
        .then(result => {
          if (result.success) {
            // Возвращаем полный URL (с доменом для Discord)
            let url = result.url;
            // Убеждаемся, что URL начинается с /
            if (!url.startsWith('/')) {
              url = '/' + url;
            }
            const fullUrl = window.location.origin + url;
            console.log('Файл загружен, URL:', fullUrl);
            resolve(fullUrl);
          } else {
            reject(new Error(result.message || 'Ошибка загрузки'));
          }
        })
        .catch(error => {
          console.error('Ошибка загрузки файла:', error);
          reject(error);
        });
      });
    }
    
    // Блоки правил
    let rulesBlocks = [];
    let rulesBlockCounter = 1;
    let rulesRuleCounter = 1;
    
    function toggleRulesBlocks() {
      const container = document.getElementById('rulesBlocksContainer');
      const btn = document.getElementById('toggleRulesBtn');
      
      if (container.style.display === 'none') {
        container.style.display = 'block';
        btn.textContent = '➖ Скрыть блоки правил';
        renderRulesBlocks();
      } else {
        container.style.display = 'none';
        btn.textContent = 'Добавить блоки правил';
      }
    }
    
    function addRulesBlock() {
      const block = {
        id: rulesBlockCounter++,
        title: '',
        rules: [],
        image: '',
        icon: ''
      };
      rulesBlocks.push(block);
      renderRulesBlocks();
      updateDescriptionWithRules();
    }
    
    function removeRulesBlock(blockId) {
      rulesBlocks = rulesBlocks.filter(b => b.id !== blockId);
      renderRulesBlocks();
      updateDescriptionWithRules();
    }
    
    function addRuleToBlock(blockId) {
      const block = rulesBlocks.find(b => b.id === blockId);
      if (block) {
        if (!block.rules) block.rules = [];
        const rule = {
          id: rulesRuleCounter++,
          number: '',
          description: '',
          punishment: '',
          duration: ''
        };
        block.rules.push(rule);
        renderRulesBlocks();
        updateDescriptionWithRules();
      }
    }
    
    function removeRuleFromBlock(blockId, ruleId) {
      const block = rulesBlocks.find(b => b.id === blockId);
      if (block && block.rules) {
        block.rules = block.rules.filter(r => r.id !== ruleId);
        renderRulesBlocks();
        updateDescriptionWithRules();
      }
    }
    
    function updateRuleField(blockId, ruleId, field, value) {
      const block = rulesBlocks.find(b => b.id === blockId);
      if (block && block.rules) {
        const rule = block.rules.find(r => r.id === ruleId);
        if (rule) {
          rule[field] = value;
          updateDescriptionWithRules();
        }
      }
    }
    
    function updateBlockField(blockId, field, value) {
      const block = rulesBlocks.find(b => b.id === blockId);
      if (block) {
        block[field] = value;
        updateDescriptionWithRules();
      }
    }
    
    function updateDescriptionWithRules() {
      const descriptionField = document.getElementById('embedDescription');
      if (!descriptionField) return;
      
      if (rulesBlocks.length === 0) {
        // Если нет блоков, не меняем описание
        return;
      }
      
      let descriptionText = descriptionField.value;
      // Удаляем старые блоки правил из описания (если они были добавлены автоматически)
      // Но сохраняем пользовательский текст, если он был введен до добавления блоков
      
      // Формируем текст из блоков правил
      let rulesText = '';
      rulesBlocks.forEach(block => {
        if (block.title) {
          rulesText += `**${escapeMarkdown(block.title)}**\n\n`;
        }
        
        if (block.rules && block.rules.length > 0) {
          block.rules.forEach((rule, index) => {
            // Убираем "Правило -" из номера если он уже там есть
            let ruleNumberText = rule.number || '';
            if (ruleNumberText) {
              // Убираем префикс "Правило -" если он уже есть
              ruleNumberText = ruleNumberText.replace(/^Правило\s*-\s*/i, '').trim();
              ruleNumberText = `**Правило - ${ruleNumberText}:**`;
            } else {
              ruleNumberText = '';
            }
            
            const ruleDescription = rule.description || '';
            const punishmentText = rule.punishment ? `\n| Наказание: **${rule.punishment}**` : '';
            const durationText = rule.duration ? `\n(Длительность: ${rule.duration})` : '';
            
            // Добавляем правило, если есть хотя бы номер, описание, наказание или длительность
            if (ruleNumberText || ruleDescription || rule.punishment || rule.duration) {
              // Формируем текст правила с переносами строк
              if (ruleNumberText) {
                if (ruleDescription) {
                  rulesText += `${ruleNumberText}\n${ruleDescription}${punishmentText}${durationText}`;
                } else {
                  rulesText += `${ruleNumberText}${punishmentText}${durationText}`;
                }
              } else {
                if (ruleDescription) {
                  rulesText += `${ruleDescription}${punishmentText}${durationText}`;
                } else {
                  rulesText += `${punishmentText}${durationText}`.trim();
                }
              }
              if (index < block.rules.length - 1) {
                rulesText += '\n\n';
              }
            }
          });
        }
      });
      
      // Добавляем правила в описание (как было раньше)
      // Сохраняем пользовательский текст перед добавлением правил
      if (!descriptionField.dataset.userText) {
        // Если пользовательский текст еще не сохранен, сохраняем текущее значение
        const currentValue = descriptionField.value.trim();
        if (currentValue && !currentValue.includes('Правило -')) {
          descriptionField.dataset.userText = currentValue;
        }
      }
      
      // Если есть пользовательский текст, добавляем его перед блоками правил
      const userText = descriptionField.dataset.userText || '';
      if (userText) {
        descriptionField.value = userText + (userText ? '\n\n' : '') + rulesText;
      } else {
        descriptionField.value = rulesText;
      }
      
      // Обновляем preview
      if (typeof updatePreview === 'function') {
        updatePreview();
      }
    }
    
    function renderRulesBlocks() {
      const container = document.getElementById('rulesBlocksList');
      if (!container) return;
      
      if (rulesBlocks.length === 0) {
        container.innerHTML = '<p style="text-align: center; color: var(--text-secondary); padding: 1rem;">Блоки правил не добавлены</p>';
        return;
      }
      
      container.innerHTML = rulesBlocks.map(block => `
        <div class="rule-block-item" data-block-id="${block.id}">
          <div class="rule-block-header">
            <input type="text" 
                   class="rule-block-title-input" 
                   value="${escapeHtml(block.title || '')}" 
                   placeholder="Название блока (например: Правила чата)"
                   onchange="updateBlockField(${block.id}, 'title', this.value)">
            <button type="button" class="rule-block-remove-btn" onclick="removeRulesBlock(${block.id})">🗑️ Удалить блок</button>
          </div>
          
          <button type="button" class="add-rule-to-block-btn" onclick="addRuleToBlock(${block.id})">Добавить правило в этот блок</button>
          
          <div class="rule-block-rules">
            ${(block.rules && block.rules.length > 0) ? '' : `
              <p style="text-align: center; color: var(--text-secondary); font-style: italic; padding: 0.5rem;">Правила в этом блоке пока не добавлены</p>
            `}
            ${(block.rules || []).map(rule => `
              <div class="rule-item">
                <div class="rule-item-header">
                  <div class="rule-item-number">Правило ${rule.number || rule.id}</div>
                  <button type="button" class="rule-item-remove-btn" onclick="removeRuleFromBlock(${block.id}, ${rule.id})">✕ Удалить</button>
                </div>
                <div class="rule-item-fields">
                  <div class="rule-item-field">
                    <label>Номер правила:</label>
                    <input type="text" 
                           value="${escapeHtml(rule.number || '')}" 
                           placeholder="Например: 2.1"
                           onchange="updateRuleField(${block.id}, ${rule.id}, 'number', this.value)">
                  </div>
                  <div class="rule-item-field">
                    <label>Описание:</label>
                    <textarea placeholder="Опишите правило..."
                              onchange="updateRuleField(${block.id}, ${rule.id}, 'description', this.value)">${escapeHtml(rule.description || '')}</textarea>
                  </div>
                  <div class="rule-item-field-row">
                    <div class="rule-item-field">
                      <label>Наказание:</label>
                      <input type="text" 
                             value="${escapeHtml(rule.punishment || '')}" 
                             placeholder="Например: Пред / мут"
                             onchange="updateRuleField(${block.id}, ${rule.id}, 'punishment', this.value)">
                    </div>
                    <div class="rule-item-field">
                      <label>Длительность:</label>
                      <input type="text" 
                             value="${escapeHtml(rule.duration || '')}" 
                             placeholder="Например: До 30 минут"
                             onchange="updateRuleField(${block.id}, ${rule.id}, 'duration', this.value)">
                    </div>
                  </div>
                </div>
              </div>
            `).join('')}
          </div>
          
          <div class="rule-block-media">
            <div class="rule-block-media-field">
              <label>Картинка:</label>
              <input type="hidden" 
                     id="block-image-${block.id}"
                     value="${escapeHtml(block.image || '')}">
              <input type="file" 
                     id="block-image-file-${block.id}"
                     accept="image/*" 
                     style="display: none;"
                     onchange="handleBlockImageUpload(${block.id}, this.files[0])">
              <button type="button" class="btn btn-secondary btn-file-upload" onclick="document.getElementById('block-image-file-${block.id}').click()" style="margin-top: 0.5rem;">Загрузить файл</button>
              <span id="block-image-name-${block.id}" class="file-name-display"></span>
              <small style="color: var(--text-secondary); font-size: 12px; display: block; margin-top: 0.5rem;">Максимальный размер: 10 МБ. Форматы: JPEG, PNG, GIF, WEBP.</small>
            </div>
            <div class="rule-block-media-field">
              <label>Иконка:</label>
              <input type="hidden" 
                     id="block-icon-${block.id}"
                     value="${escapeHtml(block.icon || '')}">
              <input type="file" 
                     id="block-icon-file-${block.id}"
                     accept="image/*" 
                     style="display: none;"
                     onchange="handleBlockIconUpload(${block.id}, this.files[0])">
              <button type="button" class="btn btn-secondary btn-file-upload" onclick="document.getElementById('block-icon-file-${block.id}').click()" style="margin-top: 0.5rem;">Загрузить файл</button>
              <span id="block-icon-name-${block.id}" class="file-name-display"></span>
              <small style="color: var(--text-secondary); font-size: 12px; display: block; margin-top: 0.5rem;">Максимальный размер: 10 МБ. Форматы: JPEG, PNG, GIF, WEBP.</small>
            </div>
          </div>
        </div>
      `).join('');
    }
    
    // Обработка загрузки картинки для блока правил
    async function handleBlockImageUpload(blockId, file) {
      if (!file) return;
      
      const nameSpan = document.getElementById(`block-image-name-${blockId}`);
      if (nameSpan) {
        nameSpan.textContent = `⏳ Загрузка ${file.name}...`;
      }
      
      try {
        const url = await uploadFile(file);
        const imageInput = document.getElementById(`block-image-${blockId}`);
        if (imageInput) {
          imageInput.value = url;
          updateBlockField(blockId, 'image', url);
        }
        if (nameSpan) {
          nameSpan.textContent = `✅ ${file.name} загружено`;
        }
      } catch (error) {
        if (nameSpan) {
          nameSpan.textContent = `❌ Ошибка: ${error.message}`;
        }
        showMessage('error', `❌ Ошибка загрузки картинки: ${error.message}`);
      }
    }
    
    // Обработка загрузки иконки для блока правил
    async function handleBlockIconUpload(blockId, file) {
      if (!file) return;
      
      const nameSpan = document.getElementById(`block-icon-name-${blockId}`);
      if (nameSpan) {
        nameSpan.textContent = `⏳ Загрузка ${file.name}...`;
      }
      
      try {
        const url = await uploadFile(file);
        const iconInput = document.getElementById(`block-icon-${blockId}`);
        if (iconInput) {
          iconInput.value = url;
          updateBlockField(blockId, 'icon', url);
        }
        if (nameSpan) {
          nameSpan.textContent = `✅ ${file.name} загружено`;
        }
      } catch (error) {
        if (nameSpan) {
          nameSpan.textContent = `❌ Ошибка: ${error.message}`;
        }
        showMessage('error', `❌ Ошибка загрузки иконки: ${error.message}`);
      }
    }
    
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
    
    function escapeMarkdown(text) {
      return text.replace(/\*/g, '\\*').replace(/_/g, '\\_').replace(/`/g, '\\`').replace(/\[/g, '\\[').replace(/\]/g, '\\]');
    }
    
    // Сохраняем пользовательский текст при изменении описания вручную
    document.addEventListener('DOMContentLoaded', () => {
      const descriptionField = document.getElementById('embedDescription');
      if (descriptionField) {
        descriptionField.addEventListener('input', function() {
          if (rulesBlocks.length === 0) {
            this.dataset.userText = this.value;
          }
        });
      }
      
    });
  </script>
</body>
</html>
